        let currentDiet = "all";
        let searchQuery = "";
        let customerMeta = { name: "", notes: "" };

        window.addEventListener("DOMContentLoaded", () => { renderFeed(); refreshCartData(); });

        function syncSearch(val) {
            searchQuery = val;
            document.getElementById("search-desktop").value = val;
            document.getElementById("search-mobile").value = val;
            renderFeed();
        }

        function syncFields(field, val) {
            customerMeta[field] = val;
            if (field === "name") {
                document.getElementById("cart-name-desktop").value = val;
                document.getElementById("cart-name-mobile").value = val;
            } else {
                document.getElementById("cart-notes-desktop").value = val;
                document.getElementById("cart-notes-mobile").value = val;
            }
        }

        function setDietFilter(diet) {
            currentDiet = diet;
            ["all","veg","nonveg","egg","drinks"].forEach(f => {
                const mob = document.getElementById(`mobile-diet-${f}`);
                const dsk = document.getElementById(`desktop-diet-${f}`);
                const cls = f === diet ? "filter-btn active flex items-center justify-center gap-1 flex-shrink-0" : "filter-btn flex items-center justify-center gap-1 flex-shrink-0";
                const dCls = f === diet ? "filter-btn active text-left flex items-center gap-2" : "filter-btn text-left flex items-center gap-2";
                if (mob) mob.className = cls;
                if (dsk) dsk.className = dCls;
            });
            renderFeed();
        }

        function scrollToCategory(catId) {
            const el = document.getElementById(`section-cat-${catId}`);
            if (el) el.scrollIntoView({ behavior: "smooth", block: "start" });
        }

        function renderFeed() {
            const feed = document.getElementById("products-feed");
            feed.innerHTML = "";
            Object.keys(CATEGORY_KEYS).forEach(catKey => {
                let items = MENU_DATA.filter(i => i.category === catKey);
                if (searchQuery.trim()) items = items.filter(i => i.name.toLowerCase().includes(searchQuery.toLowerCase()) || i.desc.toLowerCase().includes(searchQuery.toLowerCase()));
                if (currentDiet === "veg") items = items.filter(i => i.type === "veg");
                else if (currentDiet === "nonveg") items = items.filter(i => i.type === "nonveg" || i.type === "egg");
                else if (currentDiet === "egg") items = items.filter(i => i.type === "egg");
                else if (currentDiet === "drinks") items = items.filter(i => i.category === "drinks");
                if (!items.length) return;

                const sec = document.createElement("section");
                sec.id = `section-cat-${catKey}`;
                sec.className = "scroll-mt-32 lg:scroll-mt-24";
                sec.innerHTML = `
                    <div class="flex items-center justify-between mb-4 border-b border-gray-100 pb-2">
                        <h2 class="text-sm sm:text-base font-extrabold text-[#282c3f]">${CATEGORY_KEYS[catKey]}</h2>
                        <span class="text-[10px] font-bold text-gray-400 uppercase tracking-wider">${items.length} items</span>
                    </div>
                `;
                const grid = document.createElement("div");
                grid.className = "grid grid-cols-1 md:grid-cols-2 gap-3.5";
                items.forEach(item => grid.appendChild(createCardElement(item)));
                sec.appendChild(grid);
                feed.appendChild(sec);
            });

            if (!feed.children.length) {
                feed.innerHTML = `<div class="text-center py-16 bg-white rounded-2xl border border-gray-100 p-6 shadow-sm">
                    <span class="text-3xl select-none">🔍</span>
                    <h3 class="font-bold text-gray-700 mt-3 text-sm">No items found</h3>
                    <p class="text-gray-400 text-xs mt-1">Try adjusting your filters</p>
                    <button onclick="resetFilters()" class="mt-4 bg-[#fc8019] hover:bg-[#e17014] text-white font-bold px-5 py-2.5 rounded-xl text-xs transition shadow-md shadow-orange-500/10">Reset Filters</button>
                </div>`;
            }
        }

        function resetFilters() { syncSearch(""); setDietFilter("all"); }

        function createCardElement(item) {
            const card = document.createElement("div");
            card.className = "menu-card";
            const qty = cart[item.id] ? cart[item.id].qty : 0;
            const currentStyle = cart[item.id] ? cart[item.id].momoStyle : "Steamed";

            let symbolHTML = "";
            let badgeClass = "badge-drinks";
            let typeLabel = "Drinks";
            if (item.type === "veg") { 
                badgeClass = "badge-veg"; 
                typeLabel = "Veg"; 
                symbolHTML = `<span class="symbol-box text-[#0f8a65] mr-1.5"><span class="symbol-circle"></span></span>`;
            } else if (item.type === "nonveg") { 
                badgeClass = "badge-nonveg"; 
                typeLabel = "Non-Veg"; 
                symbolHTML = `<span class="symbol-box text-[#e44444] mr-1.5"><span class="symbol-triangle"></span></span>`;
            } else if (item.type === "egg") { 
                badgeClass = "badge-egg"; 
                typeLabel = "Egg"; 
                symbolHTML = `<span class="symbol-box text-[#e29c0b] mr-1.5"><span class="symbol-circle"></span></span>`;
            } else {
                symbolHTML = `<span class="symbol-box text-[#1e70e0] mr-1.5"><span class="symbol-circle"></span></span>`;
            }

            const momoHTML = item.isMomo ? `
                <div class="mt-2.5 flex items-center gap-2">
                    <span class="text-[10px] text-gray-400 font-600">Style:</span>
                    <select class="momo-select" onchange="updateMomoStyle('${item.id}', this.value)">
                        <option value="Steamed" ${currentStyle==="Steamed"?"selected":""}>💨 Steamed</option>
                        <option value="Fried" ${currentStyle==="Fried"?"selected":""}>🍳 Fried</option>
                        <option value="Garlic" ${currentStyle==="Garlic"?"selected":""}>🧄 Garlic</option>
                        <option value="Schezwan" ${currentStyle==="Schezwan"?"selected":""}>🌶️ Schezwan</option>
                        <option value="Chili" ${currentStyle==="Chili"?"selected":""}>🔥 Chili</option>
                        <option value="Korean" ${currentStyle==="Korean"?"selected":""}>🇰🇷 Korean</option>
                    </select>
                </div>` : "";

            const actionHTML = qty === 0
                ? `<button onclick="addToCart('${item.id}', event)" class="btn-add">ADD <span class="text-[10px] font-semibold text-[#fc8019] ml-0.5">+</span></button>`
                : `<div class="btn-qty"><button onclick="modifyQty('${item.id}', -1, event)">−</button><span>${qty}</span><button onclick="modifyQty('${item.id}', 1, event)">+</button></div>`;

            card.innerHTML = `
                <div class="flex gap-3.5 items-start">
                    <span class="text-3xl flex-shrink-0 select-none">${item.emoji}</span>
                    <div class="flex-1 min-w-0">
                        <div class="flex items-start justify-between gap-2">
                            <div class="min-w-0">
                                <div class="flex items-center gap-1.5 flex-wrap">
                                    ${symbolHTML}
                                    <h4 class="text-xs sm:text-sm font-bold text-[#282c3f] leading-tight truncate">${item.name}</h4>
                                    <span class="text-[8px] font-bold px-1.5 py-0.5 rounded-full ${badgeClass} uppercase tracking-wide">${typeLabel}</span>
                                </div>
                                <p class="text-[10px] text-gray-400 mt-1.5 leading-relaxed line-clamp-2">${item.desc}</p>
                                ${momoHTML}
                            </div>
                        </div>
                        <div class="flex items-center justify-between mt-3">
                            <span class="text-sm font-extrabold price-tag text-[#282c3f]">₹${item.price}</span>
                            <div id="action-node-${item.id}">${actionHTML}</div>
                        </div>
                    </div>
                </div>
            `;
            return card;
        }

        function triggerCartConfetti(event) {
            if (typeof confetti !== "function") return;
            
            let x = 0.5;
            let y = 0.5;
            
            if (event && event.currentTarget) {
                const button = event.currentTarget;
                const rect = button.getBoundingClientRect();
                x = (rect.left + rect.width / 2) / window.innerWidth;
                y = (rect.top + rect.height / 2) / window.innerHeight;
            } else if (event && event.clientX && event.clientY) {
                x = event.clientX / window.innerWidth;
                y = event.clientY / window.innerHeight;
            }
            
            confetti({
                particleCount: 80,
                spread: 120,
                startVelocity: 30,
                origin: { x, y },
                colors: ["#fc8019", "#282c3f", "#0f8a65", "#ffaa66", "#00ffff", "#ff00ff"]
            });
        }

        function addToCart(itemId, event) {
            const item = MENU_DATA.find(i => i.id === itemId);
            if (!item) return;
            cart[itemId] = { item, qty: 1, momoStyle: item.isMomo ? "Steamed" : null };
            
            triggerCartConfetti(event);
            
            triggerToast(`${item.emoji} Added to order`);
            refreshCartData();
            syncCardVisualState(itemId);
        }

        function modifyQty(itemId, delta, event) {
            if (!cart[itemId]) return;
            cart[itemId].qty += delta;
            
            if (delta > 0) {
                triggerCartConfetti(event);
            }
            
            if (cart[itemId].qty <= 0) {
                triggerToast(`Removed ${cart[itemId].item.name}`);
                delete cart[itemId];
            }
            refreshCartData();
            syncCardVisualState(itemId);
        }

        function updateMomoStyle(itemId, style) {
            const item = MENU_DATA.find(i => i.id === itemId);
            if (!cart[itemId]) cart[itemId] = { item, qty: 1, momoStyle: style };
            else cart[itemId].momoStyle = style;
            refreshCartData();
            syncCardVisualState(itemId);
        }

        function syncCardVisualState(itemId) {
            const item = MENU_DATA.find(i => i.id === itemId);
            if (!item) return;
            const node = document.getElementById(`action-node-${itemId}`);
            if (!node) return;
            const qty = cart[itemId] ? cart[itemId].qty : 0;
            node.innerHTML = qty === 0
                ? `<button onclick="addToCart('${itemId}', event)" class="btn-add">ADD <span class="text-[10px] font-semibold text-[#fc8019] ml-0.5">+</span></button>`
                : `<div class="btn-qty"><button onclick="modifyQty('${itemId}', -1, event)">−</button><span>${qty}</span><button onclick="modifyQty('${itemId}', 1, event)">+</button></div>`;
        }

        function refreshCartData() {
            const keys = Object.keys(cart);
            let totalQty = 0, totalBill = 0;
            keys.forEach(k => { totalQty += cart[k].qty; totalBill += cart[k].qty * cart[k].item.price; });

            const badgeMob = document.getElementById("cart-badge-mobile");
            if (totalQty > 0) { badgeMob.textContent = totalQty; badgeMob.classList.remove("hidden"); }
            else badgeMob.classList.add("hidden");

            const footerBar = document.getElementById("mobile-floating-cart-bar");
            if (totalQty > 0) { document.getElementById("mobile-floating-count").textContent = totalQty; footerBar.classList.remove("translate-y-full"); }
            else footerBar.classList.add("translate-y-full");

            renderDesktopCartPanel(totalBill);
            renderMobileSheetItems(totalBill);
        }

        function renderDesktopCartPanel(totalBill) {
            const wrapper = document.getElementById("desktop-cart-items");
            const checkoutBtn = document.getElementById("desktop-checkout-btn");
            const totalRow = document.getElementById("desktop-total-row");
            const totalVal = document.getElementById("desktop-total-price");
            const keys = Object.keys(cart);

            if (!keys.length) {
                wrapper.innerHTML = `<div class="text-center py-10 border border-dashed border-gray-200 rounded-xl"><span class="text-2xl select-none">🛒</span><p class="text-xs text-gray-400 font-semibold mt-2">No items yet</p></div>`;
                checkoutBtn.disabled = true;
                checkoutBtn.className = "w-full btn-disabled font-bold py-3.5 rounded-xl text-xs transition";
                checkoutBtn.textContent = "Add items to continue";
                totalRow.classList.replace("flex","hidden");
                return;
            }

            totalVal.textContent = `₹${totalBill}`;
            totalRow.classList.replace("hidden","flex");
            checkoutBtn.disabled = false;
            checkoutBtn.className = "wa-btn w-full gap-2 cursor-pointer";
            checkoutBtn.textContent = "Order via WhatsApp";

            wrapper.innerHTML = keys.map(key => {
                const { item, qty, momoStyle } = cart[key];
                const cost = item.price * qty;
                const style = momoStyle ? `<span class="text-[9px] bg-[#fffcf0] text-[#e29c0b] border border-[#fbeebf] px-1.5 py-0.5 rounded-full font-bold uppercase tracking-wider">${momoStyle}</span>` : "";
                return `<div class="bg-gray-50 p-3.5 rounded-xl border border-gray-100">
                    <div class="flex justify-between items-start gap-2">
                        <div class="min-w-0 flex-1">
                            <p class="text-xs font-bold text-[#282c3f] truncate">${item.emoji} ${item.name}</p>
                            ${style ? `<div class="mt-1">${style}</div>` : ""}
                        </div>
                        <span class="text-xs font-extrabold price-tag text-[#282c3f] flex-shrink-0">₹${cost}</span>
                    </div>
                    <div class="flex justify-between items-center mt-2.5">
                        <span class="text-[10px] text-gray-400 font-semibold">₹${item.price} each</span>
                        <div class="btn-qty text-[10px]">
                            <button onclick="modifyQty('${item.id}', -1, event)">−</button>
                            <span>${qty}</span>
                            <button onclick="modifyQty('${item.id}', 1, event)">+</button>
                        </div>
                    </div>
                </div>`;
            }).join("");
        }

        function renderMobileSheetItems(totalBill) {
            const wrapper = document.getElementById("mobile-cart-items");
            const mobTotal = document.getElementById("mobile-total-price");
            const keys = Object.keys(cart);

            if (!keys.length) {
                wrapper.innerHTML = `<div class="text-center py-10"><span class="text-3xl select-none">🛒</span><p class="text-xs text-gray-400 font-semibold mt-2">Your cart is empty</p></div>`;
                mobTotal.textContent = "₹0";
                return;
            }

            mobTotal.textContent = `₹${totalBill}`;
            wrapper.innerHTML = keys.map(key => {
                const { item, qty, momoStyle } = cart[key];
                const cost = item.price * qty;
                const style = momoStyle ? `<span class="text-[9px] bg-[#fffcf0] text-[#e29c0b] border border-[#fbeebf] px-1.5 py-0.5 rounded-full font-bold uppercase tracking-wider">${momoStyle}</span>` : "";
                return `<div class="bg-gray-50 p-3.5 rounded-xl border border-gray-100 flex items-center justify-between gap-3">
                    <div class="min-w-0 flex-1">
                        <p class="text-xs font-bold text-[#282c3f] truncate">${item.emoji} ${item.name}</p>
                        <div class="flex items-center gap-2 mt-1">
                            <span class="text-[10px] text-gray-400 font-semibold">₹${item.price}</span>
                            ${style}
                        </div>
                    </div>
                    <div class="flex items-center gap-3 flex-shrink-0">
                        <div class="btn-qty text-[10px]">
                            <button onclick="modifyQty('${item.id}', -1, event)">−</button>
                            <span>${qty}</span>
                            <button onclick="modifyQty('${item.id}', 1, event)">+</button>
                        </div>
                        <span class="text-xs font-extrabold price-tag text-[#282c3f]">₹${cost}</span>
                    </div>
                </div>`;
            }).join("");
        }

        function toggleMobileCartModal() {
            const modal = document.getElementById("mobile-cart-modal");
            const drawer = modal.querySelector(".transform");
            if (modal.classList.contains("pointer-events-none")) {
                modal.classList.remove("pointer-events-none","opacity-0");
                modal.classList.add("opacity-100");
                drawer.classList.remove("translate-y-full");
                drawer.classList.add("translate-y-0");
            } else {
                modal.classList.add("pointer-events-none","opacity-0");
                modal.classList.remove("opacity-100");
                drawer.classList.add("translate-y-full");
                drawer.classList.remove("translate-y-0");
            }
        }

        function triggerToast(text) {
            const t = document.getElementById("toast");
            t.textContent = text;
            t.style.opacity = "1";
            t.style.transform = "translate(-50%, 0)";
            setTimeout(() => { t.style.opacity = "0"; t.style.transform = "translate(-50%, -20px)"; }, 1800);
        }

        function shareMenu() {
            if (navigator.share) {
                navigator.share({ title: "ARS Authentic Recipe Station", text: "Check out our delicious recipes!", url: window.location.href });
            } else {
                const h = document.createElement("input");
                document.body.appendChild(h);
                h.value = window.location.href;
                h.select();
                document.execCommand("copy");
                document.body.removeChild(h);
                triggerToast("Link copied!");
            }
        }

        function sendOrderToWhatsApp() {
            const keys = Object.keys(cart);
            if (!keys.length) return;
            const name = customerMeta.name.trim();
            const notes = customerMeta.notes.trim();
            let totalBill = 0;
            let text = `*🍽️ Order — ARS Authentic Recipe Station*\n`;
            text += `——————————————\n`;
            if (name) text += `👤 *Name:* ${name}\n`;
            text += `📅 *Date:* ${new Date().toLocaleDateString()}\n`;
            text += `——————————————\n\n`;
            keys.forEach((key, i) => {
                const { item, qty, momoStyle } = cart[key];
                const cost = item.price * qty;
                totalBill += cost;
                const styleNote = momoStyle ? ` (${momoStyle})` : "";
                text += `${i+1}. ${item.emoji} *${item.name}*${styleNote}\n`;
                text += `   ${qty} × ₹${item.price} = *₹${cost}*\n\n`;
            });
            text += `——————————————\n`;
            if (notes) text += `📝 *Notes:* ${notes}\n`;
            text += `💰 *Total: ₹${totalBill}*\n`;
            text += `——————————————\n`;
            text += `Please confirm and let me know the estimated time!`;
            window.open(`https://wa.me/91${WHATSAPP_NUMBER}?text=${encodeURIComponent(text)}`, "_blank");
        }
    </script>
</body>
</html>
